{
  "name": "tokendesk",
  "version": "0.0.1",
  "private": true,
  "description": "TokenDesk — GitHub-authenticated pool of secrets, Cloudflare Pages",
  "scripts": {
    "dev": "wrangler pages dev ./public",
    "deploy": "wrangler pages deploy ./public",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 execute tokendesk --local --file=schema.sql",
    "db:migrate:remote": "wrangler d1 execute tokendesk --remote --file=schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240919.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.0.0"
  }
}
